# Supabase Configuration - fillgamedart
# Get these from: https://app.supabase.com/project/[project-id]/settings/api

# Supabase URL - your project's base URL
VITE_SUPABASE_URL=

# Supabase Publishable Key - safe to expose in browser
# (replaces deprecated ANON_KEY as of 2026)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_52hVd0LD0za7PRdjqoB8Xg_Y7YqR5k

# Web3Modal / WalletConnect Configuration
# Dedicated Project ID for fillgamedart (separate from fillgame)
VITE_WALLET_CONNECT_PROJECT_ID=

# ─── Switchboard On-Demand (replaces Chainlink Functions) ─────────────────
# Crossbar gateway used to fetch signed oracle updates. Override only if you
# self-host the Switchboard Crossbar.
VITE_SWITCHBOARD_CROSSBAR_URL=https://crossbar.switchboard.xyz
# Max wei to forward as the per-update Switchboard fee. Refund of surplus is
# automatic. Default 0.0005 ETH.
VITE_SWITCHBOARD_MAX_FEE_WEI=500000000000000

#Circle API_URL for bridging
CIRCLE_API_URL=

# NOTE: Smart contract addresses are configured in src/lib/contracts.ts per chain
# Do NOT hardcode contract addresses in .env - they are fetched via getContractAddress(chainId)
