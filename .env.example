# Supabase Configuration - fillingdartgame

# Supabase URL - your project's base URL
VITE_SUPABASE_URL=

# Supabase Publishable Key - safe to expose in browser
# (replaces deprecated ANON_KEY as of 2026)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_52hVd0LD0za7PRdjqoB8Xg_Y7YqR5k

# Web3Modal / WalletConnect Configuration
# Dedicated Project ID for fillingdartgame (separate from fillgame)
VITE_WALLET_CONNECT_PROJECT_ID=


#Circle API_URL for bridging
VITE_CIRCLE_API_URL=

CRON_SECRET=

# NOTE: Smart contract addresses are configured in src/lib/contracts.ts per chain
# Do NOT hardcode contract addresses in .env - they are fetched via getContractAddress(chainId)
